# AXIOM Configuration - Environment Variables
# Copy this to .env and fill in your values. NEVER commit .env to version control.

# External storage path for model weights & datasets
AXIOM_STORAGE_PATH=/Volumes/WD Drive/axiom_data

# BioASQ credentials (required for dataset download)
BIOASQ_USERNAME=
BIOASQ_PASSWORD=

# Hugging Face token (for gated model access)
HF_TOKEN=

# Device configuration
AXIOM_DEVICE=cpu
# Options: cpu, cuda, mps (Apple Silicon)
